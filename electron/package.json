{
  "name": "splace-desktop",
  "version": "4.0.0",
  "description": "SPLACE Desktop — SPlit, Align and ConcatenatE | developed by Luan Rabelo and Renato Moreira-Oliveira",
  "main": "main.js",
  "author": "Luan Rabelo and Renato Moreira-Oliveira",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "build:win": "npm run copy:highcharts && electron-builder --win --x64 --publish never",
    "build:linux": "npm run copy:highcharts && electron-builder --linux --x64 --publish never",
    "build:wsl:win": "npm run copy:highcharts && electron-builder --win --x64 --publish never",
    "build:wsl:linux": "npm run copy:highcharts && electron-builder --linux --x64 --publish never",
    "build:css": "npx @tailwindcss/cli -i ./docs/css/tailwind.input.css -o ./docs/css/tailwind.generated.css --minify",
    "copy:highcharts": "node scripts/copy-highcharts.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.2"
  },
  "build": {
    "appId": "io.github.luanrabelo.splace",
    "productName": "SPLACE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "requirements.txt",
      "PYTHON_REQUIREMENT.md",
      "WORKFLOWS.md",
      "README_V11.md"
    ],
    "extraResources": [
      {
        "from": "../docs/",
        "to": "docs",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bin/",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/run_clipkit.py",
        "to": "scripts/run_clipkit.py"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../docs/assets/SPLACE.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../docs/assets/SPLACE.png"
    }
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "highcharts": "12.4.0"
  }
}
